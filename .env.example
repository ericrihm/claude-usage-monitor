# macOS Code Signing and Notarization
# These values are required for signing macOS builds
# DO NOT commit actual values - this is just a template

# Your Apple Developer Team ID (10-character alphanumeric)
APPLE_TEAM_ID=X84UXCNLPX

# Your Apple ID email
APPLE_ID=your-apple-id@example.com

# App-specific password generated at appleid.apple.com
# Format: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Path to your .p12 certificate file
CSC_LINK=./developer_id.p12

# Password for the .p12 certificate
CSC_KEY_PASSWORD=your-certificate-password
